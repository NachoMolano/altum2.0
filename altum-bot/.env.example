# LLM — escribe "claude" o "gemini"
LLM_PROVIDER=claude

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Instagram / Meta
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=        # Token arbitrario para verificar el webhook
INSTAGRAM_PAGE_ACCESS_TOKEN=   # Token de acceso de pagina con permisos instagram_manage_messages

# Supabase PostgreSQL
# Copia la connection string de Supabase: Settings > Database > Connection string > URI
# El bot convierte automaticamente postgresql:// a postgresql+asyncpg://
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.nikgaanxfkrilkmoocyf.supabase.co:5432/postgres

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=   # JSON completo del service account como string (una linea)
GOOGLE_SPREADSHEET_ID=         # ID del spreadsheet de Google Sheets

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=              # Chat ID del asesor ALTUM que recibe el handoff
