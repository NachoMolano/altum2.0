# LLM — escribe "claude" o "gemini"
LLM_PROVIDER=claude

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Instagram / Meta
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=        # Token arbitrario para verificar el webhook
INSTAGRAM_PAGE_ACCESS_TOKEN=   # Token de acceso de pagina con permisos instagram_manage_messages

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/altum_bot

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=   # JSON completo del service account como string (una linea)
GOOGLE_SPREADSHEET_ID=         # ID del spreadsheet de Google Sheets

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=              # Chat ID del asesor ALTUM que recibe el handoff
